---
// Theme toggle component - light / dark / system
---

<div class="theme-toggle" role="radiogroup" aria-label="Theme">
  <button
    type="button"
    class="theme-option"
    role="radio"
    data-theme-choice="light"
    aria-checked="false"
    aria-label="Light theme"
    title="Light theme"
  >
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/>
      <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </button>

  <button
    type="button"
    class="theme-option"
    role="radio"
    data-theme-choice="dark"
    aria-checked="false"
    aria-label="Dark theme"
    title="Dark theme"
  >
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M21 12.79A9 9 0 1 1 11.21 3 A7 7 0 0 0 21 12.79z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
    </svg>
  </button>

  <button
    type="button"
    class="theme-option"
    role="radio"
    data-theme-choice="system"
    aria-checked="false"
    aria-label="Match system theme"
    title="Match system theme"
  >
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <rect x="3" y="4" width="18" height="12" rx="1" stroke="currentColor" stroke-width="2"/>
      <path d="M8 20h8M12 16v4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
    </svg>
  </button>
</div>

<script>
  type ThemePreference = 'light' | 'dark' | 'system';

  const STORAGE_KEY = 'theme';
  const buttons = document.querySelectorAll<HTMLButtonElement>('.theme-option');
  const media = window.matchMedia('(prefers-color-scheme: dark)');

  function getPreference(): ThemePreference {
    const stored = localStorage.getItem(STORAGE_KEY);
    return stored === 'light' || stored === 'dark' ? stored : 'system';
  }

  function resolve(preference: ThemePreference): 'light' | 'dark' {
    return preference === 'system' ? (media.matches ? 'dark' : 'light') : preference;
  }

  function applyPreference(preference: ThemePreference) {
    document.documentElement.dataset.theme = resolve(preference);
    buttons.forEach((btn) => {
      const isActive = btn.dataset.themeChoice === preference;
      btn.classList.toggle('active', isActive);
      btn.setAttribute('aria-checked', String(isActive));
    });
  }

  function setPreference(preference: ThemePreference) {
    if (preference === 'system') {
      localStorage.removeItem(STORAGE_KEY);
    } else {
      localStorage.setItem(STORAGE_KEY, preference);
    }
    applyPreference(preference);
  }

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      setPreference(btn.dataset.themeChoice as ThemePreference);
    });
  });

  media.addEventListener('change', () => {
    if (getPreference() === 'system') {
      applyPreference('system');
    }
  });

  applyPreference(getPreference());
</script>

<style>
  .theme-toggle {
    display: flex;
    align-items: center;
    border: 1px solid var(--color-border);
    border-radius: 3px;
    overflow: hidden;
  }

  .theme-option {
    background: none;
    border: none;
    padding: calc(var(--grid-unit)) calc(var(--grid-unit) * 0.75);
    cursor: pointer;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  .theme-option + .theme-option {
    border-left: 1px solid var(--color-border);
  }

  .theme-option:hover {
    color: var(--color-accent);
  }

  .theme-option.active {
    background-color: var(--color-text-primary);
    color: var(--color-background);
  }

  .theme-option.active:hover {
    color: var(--color-background);
  }

  @media (max-width: 1024px) {
    .theme-option {
      padding: calc(var(--grid-unit) * 0.6) calc(var(--grid-unit) * 0.6);
    }
  }

  @media (max-width: 480px) {
    .theme-option {
      padding: calc(var(--grid-unit) * 0.5);
    }
  }
</style>
